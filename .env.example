EZCORD_WEBAPP_URL=http://localhost:3000/ezcord

# Telegram bot integration
EZCORD_BOT_TOKEN=
EZCORD_BOT_USERNAME=ezcord_bot
EZCORD_WEBHOOK_SECRET=

# Production storage
EZCORD_DATABASE_URL=postgres://ezcord:password@127.0.0.1:5432/ezcord
EZCORD_REDIS_URL=redis://127.0.0.1:6379
EZCORD_STORAGE=postgres
EZCORD_LIVE_STATE=redis

# Optional tuning
EZCORD_PG_POOL_MAX=10
EZCORD_RATE_LIMIT_WINDOW_MS=60000
EZCORD_RATE_LIMIT_MAX=240
